# Telegram bot (iteration 1)
TELEGRAM_BOT_TOKEN=

# OpenRouter — bot and backend assistant (reuse one key)
OPENROUTER_API_KEY=
LLM_MODEL=openrouter/auto
LLM_MAX_HISTORY=10
LLM_TIMEOUT_SECONDS=30
LOG_LEVEL=INFO

# Backend service token: bot → backend Authorization Bearer
# Quote the value if it contains ':' or spaces, e.g. BACKEND_SERVICE_TOKEN="my:secret"
BACKEND_SERVICE_TOKEN=change-me
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# PostgreSQL (docker compose: host 5433 → container 5432)
DATABASE_URL=postgresql+asyncpg://diaai:diaai@localhost:5433/diaai
