# Telegram bot (основной diaai assistant — make run)
TELEGRAM_BOT_TOKEN=

# GlitchTip alerts — @diaaialarm_bot (отдельный бот, devops/glitchtip/alerts-telegram.md)
TELEGRAM_ALARM_BOT_TOKEN=
TELEGRAM_ALARM_CHAT_ID=

# Bot → backend API (task-07)
BACKEND_URL=http://127.0.0.1:8000
# Quote if value contains ':' or spaces
BACKEND_SERVICE_TOKEN=change-me

# OpenRouter — required for backend assistant (make backend-run), not for bot
OPENROUTER_API_KEY=
LLM_MODEL=openrouter/auto
LLM_MAX_HISTORY=10
LLM_TIMEOUT_SECONDS=30
STT_MODEL=openai/whisper-large-v3
STT_TIMEOUT_SECONDS=60
ANALYTICS_QUERY_MODEL=openrouter/auto
ANALYTICS_QUERY_TIMEOUT_SECONDS=5
ANALYTICS_QUERY_ROW_LIMIT=100
ANALYTICS_QUERY_LLM_TIMEOUT_SECONDS=30
LOG_LEVEL=INFO

# GlitchTip EU (hosted) — project diaai-backend: devops/glitchtip/hosted.md
# pip: already in pyproject (sentry-sdk[fastapi])
# Public ingest keys (eu.glitchtip.com org diaai); rotate in UI if repo is public
GLITCHTIP_DSN=https://0751c4291bce484985dbdeb657c1272d@eu.glitchtip.com/240
GLITCHTIP_ENVIRONMENT=development
GLITCHTIP_TRACES_SAMPLE_RATE=0.01
# Bearer token for GET /debug/glitchtip-test (empty = route disabled)
GLITCHTIP_DEBUG_TOKEN=
# GlitchTip EU — diaai-web (docker stack; see web/.env.local for pnpm dev)
GLITCHTIP_WEB_DSN=https://6b6da490a88a431cb2265981efdb5a97@eu.glitchtip.com/241
NEXT_PUBLIC_GLITCHTIP_DSN=https://6b6da490a88a431cb2265981efdb5a97@eu.glitchtip.com/241
GLITCHTIP_URL=https://eu.glitchtip.com
# Poll GlitchTip API for new issues when hosted webhook worker lags (backend poller)
GLITCHTIP_ORG=diaai
GLITCHTIP_API_TOKEN=
GLITCHTIP_POLL_INTERVAL_SECONDS=60

# Monitoring (devops/monitoring — ADR-005)
# Prod: make monitoring-up после stack-up-registry (task 02)
DOZZLE_BIND=127.0.0.1:8888
GLITCHTIP_BRIDGE_BIND=8080:8080
UPTIME_KUMA_BIND=127.0.0.1:3002:3001
GLITCHTIP_EMAIL_BRIDGE_BIND=8081:8081
GLITCHTIP_WEBHOOK_SECRET=

# GlitchTip → email bridge (devops/glitchtip/alerts-email.md)
GLITCHTIP_ALERT_EMAIL_TO=
GLITCHTIP_ALERT_EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=false

# Prod VPS: Docker cannot reach SMTP — relay on host (see compose.server.override.yml)
# GLITCHTIP_SMTP_RELAY_URL=http://host.docker.internal:9090/send
# SMTP_RELAY_TOKEN=
# SMTP_RELAY_PORT=9090

# Backend server bind (make backend-run)
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# PostgreSQL (docker compose: host 5433 → container 5432; make db-reset для чистой seeded БД)
DATABASE_URL=postgresql+asyncpg://diaai:diaai@localhost:5433/diaai

# Web client (web/.env.local) — server-only BFF; browser URL for iter 3+:
# NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8000
