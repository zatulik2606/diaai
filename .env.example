# Telegram bot
TELEGRAM_BOT_TOKEN=

# Bot → backend API (task-07)
BACKEND_URL=http://127.0.0.1:8000
# Quote if value contains ':' or spaces
BACKEND_SERVICE_TOKEN=change-me

# OpenRouter — required for backend assistant (make backend-run), not for bot
OPENROUTER_API_KEY=
LLM_MODEL=openrouter/auto
LLM_MAX_HISTORY=10
LLM_TIMEOUT_SECONDS=30
LOG_LEVEL=INFO

# Backend server bind (make backend-run)
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# PostgreSQL (docker compose: host 5433 → container 5432; make db-reset для чистой seeded БД)
DATABASE_URL=postgresql+asyncpg://diaai:diaai@localhost:5433/diaai
