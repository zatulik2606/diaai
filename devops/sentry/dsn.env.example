# Sentry on-premise — Client Keys (после создания проектов)
#
# Скопировать: cp devops/sentry/dsn.env.example devops/sentry/dsn.local.env
# Затем значения из Sentry UI или scripts/create-projects.sh → корневой .env и web/.env.local
#
# UI: Settings → Projects → {project} → Client Keys (DSN)

# Базовый URL self-hosted Sentry (без trailing slash)
SENTRY_URL=http://127.0.0.1:9000
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Проект diaai-backend (FastAPI) ---
# Settings → Projects → diaai-backend → Client Keys → корневой .env
SENTRY_DSN=

# --- Проект diaai-web (Next.js) ---
# Settings → Projects → diaai-web → Client Keys
WEB_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Опционально: upload source maps при build web (Internal Integration → Auth Token)
# SENTRY_ORG=diaai
# SENTRY_PROJECT=diaai-web
# SENTRY_AUTH_TOKEN=
