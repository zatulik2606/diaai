# sentry.io (SaaS) — Client Keys после create-projects-cloud.sh
#
# cp devops/sentry/dsn.cloud.env.example devops/sentry/dsn.cloud.local.env
# или: bash devops/sentry/scripts/create-projects-cloud.sh

SENTRY_URL=https://sentry.io
SENTRY_ORG=diaai
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# --- diaai-backend (FastAPI) ---
SENTRY_DSN=

# --- diaai-web (Next.js) ---
WEB_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Source maps upload (optional, web build)
# SENTRY_PROJECT=diaai-web
# SENTRY_AUTH_TOKEN=
