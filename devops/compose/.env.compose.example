# Stack-specific env overrides (reference).
# Secrets stay in root .env — copy from .env.example.
# Compose applies overrides in docker-compose.yml environment: blocks.

# Inside Docker network (backend service):
# DATABASE_URL=postgresql+asyncpg://diaai:diaai@postgres:5432/diaai

# Bot and web BFF (inside Docker network):
# BACKEND_URL=http://backend:8000

# Host-side db-* commands still use .env:
# DATABASE_URL=postgresql+asyncpg://diaai:diaai@localhost:5433/diaai

# Required in .env before stack-up:
# BACKEND_SERVICE_TOKEN=<secure-not-change-me>
# OPENROUTER_API_KEY=<key>
# TELEGRAM_BOT_TOKEN=<token>  # only for bot profile

# Registry mode (iter 1) — defaults in Makefile:
# GHCR_OWNER=zatulik2606
# IMAGE_TAG=main
# DIAAI_BACKEND_IMAGE=ghcr.io/zatulik2606/diaai-backend:main
# make stack-pull-registry && make stack-up-registry
