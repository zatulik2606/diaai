# GlitchTip on VPS — copy to .env (chmod 600, not in git)
# Generate: openssl rand -hex 32

SECRET_KEY=change_me_openssl_rand_hex_32
POSTGRES_PASSWORD=change_me_pg_password
DATABASE_URL=postgres://glitchtip:change_me_pg_password@postgres:5432/glitchtip

# Public URL (http until nginx+SSL; include scheme)
GLITCHTIP_DOMAIN=http://GLITCHTIP_IP:8000

VALKEY_URL=redis://valkey:6379/0
DEFAULT_FROM_EMAIL=noreply@example.com
# MVP without SMTP — events in logs only:
EMAIL_URL=consolemail://

GLITCHTIP_MAX_EVENT_LIFE_DAYS=90
ENABLE_USER_REGISTRATION=true
ENABLE_ORGANIZATION_CREATION=true

# After first admin signup → set false and docker compose up -d
# ENABLE_USER_REGISTRATION=false
